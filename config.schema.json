{
  "$defs": {
    "AppSecrets": {
      "properties": {
        "jwt_secret_key": {
          "format": "password",
          "title": "Jwt Secret Key",
          "type": "string",
          "writeOnly": true
        },
        "session_secret_key": {
          "format": "password",
          "title": "Session Secret Key",
          "type": "string",
          "writeOnly": true
        },
        "db_username": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Username"
        },
        "db_password": {
          "anyOf": [
            {
              "format": "password",
              "type": "string",
              "writeOnly": true
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Password"
        }
      },
      "required": [
        "jwt_secret_key",
        "session_secret_key"
      ],
      "title": "AppSecrets",
      "type": "object"
    },
    "AppSettings": {
      "properties": {
        "api_host": {
          "default": "127.0.0.1",
          "title": "Api Host",
          "type": "string"
        },
        "api_port": {
          "default": 8666,
          "title": "Api Port",
          "type": "integer"
        },
        "app_host": {
          "default": "localhost",
          "title": "App Host",
          "type": "string"
        },
        "app_port": {
          "default": 5173,
          "title": "App Port",
          "type": "integer"
        },
        "web_host": {
          "default": "localhost",
          "title": "Web Host",
          "type": "string"
        },
        "web_port": {
          "default": 5174,
          "title": "Web Port",
          "type": "integer"
        },
        "jwt_interview_token_expiration": {
          "$ref": "#/$defs/TimeDelta"
        },
        "jwt_auth_token_expiration": {
          "$ref": "#/$defs/TimeDelta"
        },
        "jwt_invite_token_expiration": {
          "$ref": "#/$defs/TimeDelta"
        },
        "registration_requires_token": {
          "default": true,
          "title": "Registration Requires Token",
          "type": "boolean"
        }
      },
      "title": "AppSettings",
      "type": "object"
    },
    "DatabaseSettings": {
      "properties": {
        "db": {
          "$ref": "#/$defs/DatabaseType",
          "default": "sqlite"
        },
        "db_path": {
          "default": "storage",
          "title": "Db Path",
          "type": "string"
        },
        "db_url": {
          "default": "localhost",
          "title": "Db Url",
          "type": "string"
        },
        "db_port": {
          "default": "5432",
          "title": "Db Port",
          "type": "string"
        },
        "db_name": {
          "default": "ainterviewer",
          "title": "Db Name",
          "type": "string"
        },
        "default_team_id": {
          "format": "uuid4",
          "title": "Default Team Id",
          "type": "string"
        }
      },
      "required": [
        "default_team_id"
      ],
      "title": "DatabaseSettings",
      "type": "object"
    },
    "DatabaseType": {
      "enum": [
        "sqlite",
        "postgresql"
      ],
      "title": "DatabaseType",
      "type": "string"
    },
    "EmailAccount": {
      "properties": {
        "email": {
          "title": "Email",
          "type": "string"
        },
        "password": {
          "format": "password",
          "title": "Password",
          "type": "string",
          "writeOnly": true
        }
      },
      "required": [
        "email",
        "password"
      ],
      "title": "EmailAccount",
      "type": "object"
    },
    "EmailSettings": {
      "properties": {
        "smtp_server": {
          "title": "Smtp Server",
          "type": "string"
        },
        "smtp_port": {
          "default": 587,
          "title": "Smtp Port",
          "type": "integer"
        },
        "smtp_use_ssl": {
          "default": false,
          "title": "Smtp Use Ssl",
          "type": "boolean"
        },
        "sender": {
          "$ref": "#/$defs/EmailAccount"
        },
        "recipient": {
          "$ref": "#/$defs/EmailAccount"
        }
      },
      "required": [
        "smtp_server",
        "sender",
        "recipient"
      ],
      "title": "EmailSettings",
      "type": "object"
    },
    "ServiceSettings": {
      "description": "Different extra services required to run the app",
      "properties": {
        "email": {
          "$ref": "#/$defs/EmailSettings"
        }
      },
      "required": [
        "email"
      ],
      "title": "ServiceSettings",
      "type": "object"
    },
    "TimeDelta": {
      "properties": {
        "days": {
          "default": 0,
          "title": "Days",
          "type": "integer"
        },
        "seconds": {
          "default": 0,
          "title": "Seconds",
          "type": "integer"
        },
        "microseconds": {
          "default": 0,
          "title": "Microseconds",
          "type": "integer"
        },
        "milliseconds": {
          "default": 0,
          "title": "Milliseconds",
          "type": "integer"
        },
        "minutes": {
          "default": 0,
          "title": "Minutes",
          "type": "integer"
        },
        "hours": {
          "default": 0,
          "title": "Hours",
          "type": "integer"
        },
        "weeks": {
          "default": 0,
          "title": "Weeks",
          "type": "integer"
        }
      },
      "title": "TimeDelta",
      "type": "object"
    },
    "LLMSettings": {
      "properties": {
        "llm_host": {
          "default": "0.0.0.0",
          "title": "Llm Host",
          "type": "string"
        },
        "llm_port": {
          "default": 8880,
          "title": "Llm Port",
          "type": "integer"
        },
        "model_storage": {
          "default": "local",
          "enum": [
            "local",
            "s3_bucket"
          ],
          "title": "Model Storage",
          "type": "string"
        },
        "available_models": {
          "items": {
            "type": "string"
          },
          "title": "Available Models",
          "type": "array"
        },
        "default_model": {
          "default": "gpt-5-mini",
          "title": "Default Model",
          "type": "string"
        },
        "demo_models": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Demo Models"
        },
        "default_demo_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Demo Model"
        },
        "seed": {
          "default": 4268,
          "title": "Seed",
          "type": "integer"
        }
      },
      "title": "LLMSettings",
      "type": "object"
    },
    "MediaStorageSettings": {
      "description": "Central configuration for all media storage.",
      "properties": {
        "base_path": {
          "default": "storage",
          "format": "path",
          "title": "Base Path",
          "type": "string"
        }
      },
      "title": "MediaStorageSettings",
      "type": "object"
    },
    "Secrets": {
      "properties": {
        "openai_api_key": {
          "anyOf": [
            {
              "format": "password",
              "type": "string",
              "writeOnly": true
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Openai Api Key"
        },
        "google_ai_api_key": {
          "anyOf": [
            {
              "format": "password",
              "type": "string",
              "writeOnly": true
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Google Ai Api Key"
        },
        "openrouter_api_key": {
          "anyOf": [
            {
              "format": "password",
              "type": "string",
              "writeOnly": true
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Openrouter Api Key"
        },
        "vllm_api_key": {
          "default": "",
          "format": "password",
          "title": "Vllm Api Key",
          "type": "string",
          "writeOnly": true
        }
      },
      "title": "Secrets",
      "type": "object"
    }
  },
  "properties": {
    "debug": {
      "allOf": [
        {
          "default": false,
          "title": "Debug",
          "type": "boolean"
        },
        {
          "default": false,
          "title": "Debug",
          "type": "boolean"
        }
      ]
    },
    "app_env": {
      "default": "development",
      "enum": [
        "production",
        "staging",
        "development"
      ],
      "title": "App Env",
      "type": "string"
    },
    "app": {
      "$ref": "#/$defs/AppSettings"
    },
    "database": {
      "$ref": "#/$defs/DatabaseSettings"
    },
    "services": {
      "$ref": "#/$defs/ServiceSettings"
    },
    "secrets": {
      "allOf": [
        {
          "$ref": "#/$defs/AppSecrets"
        },
        {
          "$ref": "#/$defs/Secrets"
        }
      ]
    },
    "tzinfo": {
      "default": "Europe/Copenhagen",
      "format": "zoneinfo",
      "title": "Tzinfo",
      "type": "string"
    },
    "llm": {
      "$ref": "#/$defs/LLMSettings",
      "default": {
        "llm_host": "0.0.0.0",
        "llm_port": 8880,
        "model_storage": "local",
        "available_models": [
          "gpt-5-mini"
        ],
        "default_model": "gpt-5-mini",
        "demo_models": [
          "gpt-5-mini"
        ],
        "default_demo_model": "gpt-5-mini",
        "seed": 4268,
        "llm_endpoint": "http://0.0.0.0:8880"
      }
    },
    "storage": {
      "$ref": "#/$defs/MediaStorageSettings",
      "default": {
        "base_path": "storage"
      }
    }
  },
  "required": [
    "app",
    "database",
    "services"
  ],
  "title": "Settings",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#"
}