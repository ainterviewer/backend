<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>AInterviewer - Automated Structured Interviews at Scale</title>
        <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        ul {
          background-color: #f8f9fa; padding: 25px; border-radius: 6px; margin: 25px 0; list-style-type: none; padding-left: 0;

        }

        ul > li {
            margin-bottom: 15px;
            margin-left: 15px;
          }
        ul > li > span.icon{
          display: inline-block;
          width: 20px;
          height: 20px;
          background-color: #196858;
          border-radius: 50%;
          margin-right: 15px;
          vertical-align: middle;
        }

        ul > li > span {
          vertical-align: middle;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f8f9fa;
        }

        img {
          width: 100%;
        }
        
        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        
        .content {
            padding: 40px 30px;
        }
        
        .greeting {
            font-size: 18px;
            margin-bottom: 20px;
            color: #2c3e50;
        }
        
        .main-text {
            font-size: 16px;
            margin-bottom: 25px;
            color: #555;
        }

        .features {
            background-color: #f8f9fa;
            padding: 25px;
            border-radius: 6px;
            margin: 25px 0;
        }
        
        .feature-item {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .feature-icon {
            width: 20px;
            height: 20px;
            background: linear-gradient(135deg, #1c2826 0%, #196858 100%);
            border-radius: 50%;
            margin-right: 15px;
            flex-shrink: 0;
        }
        
        .cta-button {
            display: inline-block;
            background: #196858;
            color: #ffffff !important;
            text-decoration: none;
            padding: 15px 30px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 20px;
            transition: transform 0.2s ease;
        }
        
        .cta-button:hover {
            transform: translateY(-2px);
            color:white;
        }
        
        .footer {
            background-color: #f1f3f4;
            padding: 30px;
            text-align: center;
            font-size: 14px;
            color: #666;
            border-top: 1px solid #e0e0e0;
        }
        
        .social-links {
            margin: 20px 0;
        }
        
        .social-links a {
            color: #667eea;
            text-decoration: none;
            margin: 0 10px;
        }
        
        .unsubscribe {
            margin-top: 20px;
            font-size: 12px;
            color: #999;
        }
        
        .unsubscribe a {
            color: #999;
            text-decoration: underline;
        }
        
        /* Mobile responsiveness */
        @media (max-width: 600px) {
            .container {
                margin: 0;
                border-radius: 0;
            }
            
            .header, .content, .footer {
                padding: 20px;
            }
            
            .logo {
                font-size: 24px;
            }
            
            .tagline {
                font-size: 14px;
            }
        }

        </style>
    </head>
    <body>
        <div class="container">
            <img src="cid:email_header">
            <!-- Main Content -->
            <div class="content">
                <div class="greeting">Hello {{ recipient_name }},</div>
                {% block content %}{% endblock %}
                {% if greeting|default(True) %}
                    <div class="greeting" style="margin-top: 40px;">
                        Best regards,
                        <br>
                        {% if sender_name|default(False) %}
                            {{ sender_name }}
                        {% else %}
                            AInterviewer Team
                        {% endif %}
                    </div>
                {% endif %}
            </div>
            <!-- Footer -->
            <div class="footer">
                <div>
                    <strong>AInterviewer.dk</strong>
                    <br>
                    Automated structured interviews at scale
                </div>
                <div class="social-links">
                    <a href="https://ainterviewer.dk">Visit Website</a> |
                    <a href="mailto:contact@ainterviewer.dk">Contact Us</a>
                </div>
                {% if show_unsubscribe|default(False) %}
                    <div class="unsubscribe">
                        You received this email because you're interested in AInterviewer.
                        <br>
                        <a href="{{ unsubscribe_link }}">Unsubscribe</a> |
                        <a href="{{ preferences_link }}">Update Preferences</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </body>
</html>
